# ──────────────────────────────────────────────────────────────────
# PhishGuard Environment Variables — EXAMPLE
# Copy this file to .env and fill in your real values
# ──────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_PORT=5000

# Database
DB_PATH=phishguard.db

# GoPhish (get API key from GoPhish Settings page)
GOPHISH_URL=https://127.0.0.1:3333
GOPHISH_API_KEY=your-gophish-api-key-here

# Server URLs (change if deploying to a server)
FRONTEND_URL=http://127.0.0.1:8088
BACKEND_URL=http://127.0.0.1:5000

# Default admin credentials (first run only)
ADMIN_EMAIL=admin@phishguard.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Super Admin
